# ===============================
# Adding Bot required
# ===============================
BOT_TOKEN=your_bot_token_here
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=waifu_adding_v2
OWNER_ID=123456789
# OWNER_IDS=123456789,987654321

LOG_LEVEL=INFO
DEFAULT_COMMAND=/hallow
DEFAULT_SOURCE_KEY=characters_hallow
OWNER_USERNAME=@Official_Bika
ADDED_LOG_CHANNEL=@WaifuAddedList

# AddHelper and target chat save-only need this group/chat id
DEFAULT_TARGET_CHAT=-1001234567890

PHOTO_PHASH_THRESHOLD=8
VIDEO_FRAME_THRESHOLD=10
VIDEO_AVG_THRESHOLD=12

# VPS + PM2 usually false. Render webhook can be true.
USE_WEBHOOK=false
PUBLIC_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
PORT=8080

# ===============================
# AddHelper userbot
# ===============================
ADD_HELPER_ENABLED=true
API_ID=1234567
API_HASH=your_api_hash_here
SESSION_STRING=your_pyrogram_session_string_here

DEFAULT_SEND_DELAY=5
MAX_SEND_DELAY=30
MAX_RETRIES=5
RETRY_BASE_DELAY=3
CONTROL_POLL_INTERVAL=2
CONTROL_HISTORY_LIMIT=25
STATE_FILE=seeder_state.json
CLEAR_STATE_ON_FINISH=true
SESSIONS_DIR=sessions
ADD_HELPER_STARTUP_MESSAGE=true

# Optional inline source overrides
CATCHER_INLINE_BOT=@Character_Catcher_Bot
SEIZER_INLINE_BOT=@Character_Seizer_Bot
CAPTURE_INLINE_BOT=@CaptureCharacterBot
TAKERS_INLINE_BOT=@Takers_character_bot
GRAB_INLINE_BOT=@Grab_Your_Waifu_Bot

# Optional forward source overrides
FW_HALLOW_SOURCE_CHAT=@hallowuploads
FW_SEIZER_SOURCE_CHAT=@Seizer_Database
FW_CAPTURE_SOURCE_CHAT=@CaptureDatabase

# New style optional overrides. Usually not needed.
INLINE_HUSBANDO_GRABBER=@Husbando_Grabber_Bot
INLINE_GRAB_YOUR_HUSBANDO=@Grab_Your_Husbando_Bot
INLINE_CATCH_YOUR_HUSBANDO=@Catch_Your_Husbando_Bot
INLINE_SMASH_CHARACTER=@Smash_Character_Bot
INLINE_WAIFUX_GRAB=@WaifuxGrabBot
INLINE_CATCH_YOUR_WAIFU=@Catch_Your_Waifu_Bot
INLINE_WAIFU_GRABBER=@Waifu_Grabber_Bot
